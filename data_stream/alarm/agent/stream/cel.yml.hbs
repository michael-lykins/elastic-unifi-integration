interval: {{interval}}
program: |
  request("GET",
    state.url + "/proxy/network/api/s/{{site}}/rest/alarm"
  ).with({
    "Header": {
      "X-API-KEY": ["{{api_key}}"],
      "Accept":    ["application/json"]
    }
  }).do_request().as(resp, resp.StatusCode == 200 ?
    {
      "events": bytes(resp.Body).decode_json().data.filter(a,
        !has(a.archived) || !a.archived
      ).map(a, {
        "unifi": {
          "alarm": {
            "key":        has(a.key)       ? string(a.key)       : "",
            "msg":        has(a.msg)       ? string(a.msg)       : "",
            "subsystem":  has(a.subsystem) ? string(a.subsystem) : "",
            "archived":   has(a.archived)  ? a.archived           : false,
            "device_mac": has(a.sw)        ? string(a.sw)         :
                          has(a.ap)        ? string(a.ap)         :
                          has(a.gw)        ? string(a.gw)         : "",
            "client_mac": has(a.client)    ? string(a.client)    : ""
          }
        },
        "message": has(a.msg) ? string(a.msg) : "",
        "event":   {"dataset": "unifi.alarm", "module": "unifi"},
        "service": {"name": "unifi"}
      })
    }
  :
    {
      "events": [],
      "want_more": false
    }
  )
resource.url: '{{url}}'
state:
  url: '{{url}}'
resource.ssl.verification_mode: '{{ssl_verification_mode}}'
tags:
  - unifi-alarm
  - forwarded
