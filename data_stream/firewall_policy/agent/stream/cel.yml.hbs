interval: {{interval}}
program: |
  // Each collection interval makes three sequential requests:
  //   1. GET /sites              → resolve the UDM-Pro site UUID
  //   2. GET /sites/{id}/firewall/zones    → build zone-name lookup
  //   3. GET /sites/{id}/firewall/policies → emit one doc per policy rule
  //
  // Full filter details (MACs, IPs, ports, protocol) are captured so that a
  // fingerprint processor can hash the complete rule config for change detection.
  request("GET",
    state.url + "/proxy/network/integration/v1/sites"
  ).with({
    "Header": {
      "X-API-KEY": ["{{api_key}}"],
      "Accept":    ["application/json"]
    }
  }).do_request().as(sites_resp,
    sites_resp.StatusCode != 200 ?
      {"events": [], "want_more": false}
    :
    bytes(sites_resp.Body).decode_json().data.filter(
      x, x.internalReference == "{{site}}"
    ).as(match,
      match.size() == 0 ?
        {"events": [], "want_more": false}
      :
      match[0].id.as(site_id,
        request("GET",
          state.url + "/proxy/network/integration/v1/sites/" + site_id + "/firewall/zones"
        ).with({
          "Header": {
            "X-API-KEY": ["{{api_key}}"],
            "Accept":    ["application/json"]
          }
        }).do_request().as(zones_resp,
          zones_resp.StatusCode != 200 ?
            {"events": [], "want_more": false}
          :
          bytes(zones_resp.Body).decode_json().data.map(
            z, {"id": z.id, "name": z.name}
          ).as(zones,
            request("GET",
              state.url + "/proxy/network/integration/v1/sites/" + site_id +
              "/firewall/policies?limit=100"
            ).with({
              "Header": {
                "X-API-KEY": ["{{api_key}}"],
                "Accept":    ["application/json"]
              }
            }).do_request().as(pol_resp,
              pol_resp.StatusCode != 200 ?
                {"events": [], "want_more": false}
              :
              bytes(pol_resp.Body).decode_json().data.map(p,
                {
                  "unifi": {
                    "firewall_policy": {
                      "id":      p.id,
                      "name":    has(p.name) ? string(p.name) : "",
                      "enabled": p.enabled,
                      "index":   int(p.index),
                      "action": {
                        "type":                p.action.type,
                        "allow_return_traffic": has(p.action.allowReturnTraffic) ? p.action.allowReturnTraffic : false
                      },
                      // ── Source filter ────────────────────────────────────
                      "source": {
                        "zone_id":     p.source.zoneId,
                        "zone_name":   zones.filter(z, z.id == p.source.zoneId).as(m,
                                         m.size() > 0 ? m[0].name : p.source.zoneId),
                        "filter_type": has(p.source.trafficFilter) ? p.source.trafficFilter.type : "ANY",
                        "mac_addresses": (has(p.source.trafficFilter) &&
                                          has(p.source.trafficFilter.macAddressFilter) &&
                                          has(p.source.trafficFilter.macAddressFilter.macAddresses))
                                         ? p.source.trafficFilter.macAddressFilter.macAddresses : [],
                        "ip_addresses": (has(p.source.trafficFilter) &&
                                         has(p.source.trafficFilter.ipAddressFilter) &&
                                         has(p.source.trafficFilter.ipAddressFilter.items))
                                        ? p.source.trafficFilter.ipAddressFilter.items.map(i, string(i.value)) : [],
                        "ports":        (has(p.source.trafficFilter) &&
                                         has(p.source.trafficFilter.portFilter) &&
                                         has(p.source.trafficFilter.portFilter.items))
                                        ? p.source.trafficFilter.portFilter.items.map(i, string(i.value)) : []
                      },
                      // ── Destination filter ───────────────────────────────
                      "destination": {
                        "zone_id":     p.destination.zoneId,
                        "zone_name":   zones.filter(z, z.id == p.destination.zoneId).as(m,
                                         m.size() > 0 ? m[0].name : p.destination.zoneId),
                        "filter_type": has(p.destination.trafficFilter) ? p.destination.trafficFilter.type : "ANY",
                        "mac_addresses": (has(p.destination.trafficFilter) &&
                                          has(p.destination.trafficFilter.macAddressFilter) &&
                                          has(p.destination.trafficFilter.macAddressFilter.macAddresses))
                                         ? p.destination.trafficFilter.macAddressFilter.macAddresses : [],
                        "ip_addresses": (has(p.destination.trafficFilter) &&
                                         has(p.destination.trafficFilter.ipAddressFilter) &&
                                         has(p.destination.trafficFilter.ipAddressFilter.items))
                                        ? p.destination.trafficFilter.ipAddressFilter.items.map(i, string(i.value)) : [],
                        "ports":        (has(p.destination.trafficFilter) &&
                                         has(p.destination.trafficFilter.portFilter) &&
                                         has(p.destination.trafficFilter.portFilter.items))
                                        ? p.destination.trafficFilter.portFilter.items.map(i, string(i.value)) : []
                      },
                      // ── Protocol scope ───────────────────────────────────
                      // ip_version: IPV4, IPV6, or IPV4_AND_IPV6
                      // ip_protocol: TCP, UDP, ICMP, ICMPv6, etc. — "ANY" when not restricted.
                      // A missing ip_protocol means no protocol filter (catches all traffic).
                      // This field is critical: the WAN ICMP rules had no ip_protocol set,
                      // making them ACCEPT-ALL rules despite being named for ICMP only.
                      "ip_version":  has(p.ipProtocolScope) && has(p.ipProtocolScope.ipVersion)
                                     ? string(p.ipProtocolScope.ipVersion) : "",
                      "ip_protocol": has(p.ipProtocolScope) && has(p.ipProtocolScope.ipProtocol)
                                     ? string(p.ipProtocolScope.ipProtocol) : "ANY",
                      "logging_enabled": p.loggingEnabled,
                      "origin":          has(p.metadata) && has(p.metadata.origin) ? string(p.metadata.origin) : ""
                    }
                  },
                  "event":   {"dataset": "unifi.firewall_policy", "module": "unifi"},
                  "service": {"name": "unifi"}
                }
              ).as(events,
                {"events": events, "want_more": false}
              )
            )
          )
        )
      )
    )
  )
resource.url: '{{url}}'
state:
  url: '{{url}}'
resource.ssl.verification_mode: '{{ssl_verification_mode}}'
tags:
  - unifi-firewall-policy
  - forwarded
